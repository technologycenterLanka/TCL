<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the requested file or directory exists inside the /dist folder, serve it
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
  RewriteRule ^(.*)$ /dist/$1 [L]

  # If the requested file does not exist (e.g., React router paths like /about), 
  # fallback to serving the compiled index.html from the /dist folder
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteRule ^(.*)$ /dist/index.html [L]
</IfModule>
